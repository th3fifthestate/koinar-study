# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Next.js
app/.next/
app/out/

# Database files — ignore runtime DB artifacts but keep static reference
# data (seeds, tipnr) under app/data/. Using broad `app/data/` with
# negation doesn't work because git doesn't recurse into an ignored
# directory even with `!app/data/seeds/**` rules. Instead, target only
# the runtime artifacts:
/data/
*.db
*.db-wal
*.db-shm
app/data/app.db*
app/data/backups/
app/data/sqlite/
app/data/databases/
app/data/last-entity-batch.json
app/data/**/*.db
app/data/**/*.db-wal
app/data/**/*.db-shm

# Build output
app/dist/
app/.turbo/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated exports
app/exports/

# Docker
.docker/

# Superpowers (local config)
.superpowers/

# Founders Files
founders-files/
docs/
briefs/
design-references/
app-designs/

# Dependencies (rebuilt in Docker)
node_modules
npm-debug.log*

# Build output (rebuilt in Docker)
.next
out
dist

# Environment files with secrets
.env
.env.local
.env.*.local

# Database files — exclude only the dev DB, not the whole data/ tree.
# Seed source (data/seeds/*.json, data/tipnr/*.tsv) ships in the image
# and is required by scripts/seed-entities.ts and scripts/import-tipnr.ts.
data/app.db
data/app.db-wal
data/app.db-shm
data/backups/
*.db
*.db-wal
*.db-shm

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation (not needed in image)
README.md
CLAUDE.md
AGENTS.md
LICENSE

# TypeScript build info
*.tsbuildinfo

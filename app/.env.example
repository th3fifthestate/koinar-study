# =============================================================================
# Koinar Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/app.db

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64+ characters (32 bytes hex) in production
SESSION_SECRET=

# AI — Study Generation
ANTHROPIC_API_KEY=
AI_MODEL_ID=claude-opus-4-6

# Email — Resend
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Image Generation — Flux (via BFL)
FLUX_API_KEY=

# Cloudflare R2 — Image Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=koinar-images
R2_PUBLIC_URL=images.koinar.app

# Translation APIs (Post-Launch)
ESV_API_KEY=
NLT_API_KEY=
API_BIBLE_KEY=

# BYOK Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

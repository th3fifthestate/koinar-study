# =============================================================================
# Koinar Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/app.db
BIBLE_DB_PATH=./data/databases

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64+ characters (32 bytes hex) in production
SESSION_SECRET=

# AI — Study Generation
ANTHROPIC_API_KEY=
# Anthropic model ID. Current default: claude-opus-4-6 (Opus 4.6, $5/$25 per MTok, 1M ctx, 128k out). See https://platform.claude.com/docs/en/docs/about-claude/models/overview for current options.
AI_MODEL_ID=claude-opus-4-6
# IMPORTANT: if ANTHROPIC_BASE_URL is set in your shell (e.g. "https://api.anthropic.com" for @anthropic-ai/sdk),
# the @ai-sdk/anthropic package will inherit it and produce 404s (missing /v1). The route now pins
# baseURL explicitly in code, so this var is ignored for study generation. For a custom proxy, update route.ts.
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Email — Resend
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Image Generation — Flux (via BFL)
FLUX_API_KEY=

# Cloudflare R2 — Image Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=koinar-images
R2_PUBLIC_URL=images.koinar.app

# Bible Translation APIs
# ESV: https://api.esv.org — free tier for non-commercial use
ESV_API_KEY=
# API.Bible: https://scripture.api.bible — key grants access to all licensed translations
API_BIBLE_KEY=
# Bible IDs for API.Bible licensed translations (look up via GET /v1/bibles after first deploy)
API_BIBLE_ID_NLT=
API_BIBLE_ID_NIV=
API_BIBLE_ID_NASB=
# Kill-switch: set to "true" to hide all licensed translations app-wide (ABS termination)
ABS_PURGE_ENABLED=false

# BYOK Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64+ characters in production
ENCRYPTION_KEY=
